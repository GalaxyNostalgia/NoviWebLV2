<!doctype html>
<html lang="hr">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>Galerija</title>
  <link rel="stylesheet" href="/style/style_slike.css" />
</head>
<body>
  <main>
    <h1>Galerija slika</h1>

    <nav aria-label="Glavna navigacija">
			<ul class="nav-menu">
				<li>
				<a href="#">Navigacija ▼</a>
				<ul class="dropdown">
					<li><a href="index.html">Početna</a></li>
					<li><a href="slike.html">Galerija</a></li>
					<li><a href="grafikon.html">Grafikon</a></li>
				</ul>
				</li>
			</ul>
		</nav>

    <section class="gallery" aria-label="Galerija slika">
      <% images.forEach(image => { %>
        <figure>
          <a href="#<%= image.id %>">
            <img src="<%= image.url %>" alt="<%= image.title %>" loading="lazy">
          </a>
          <figcaption><%= image.title %></figcaption>
        </figure>

        <!-- Lightbox overlay (anchor target) -->
        <div class="lightbox" id="<%= image.id %>" aria-label="<%= image.title %>">
          <a class="close" href="/slike" aria-label="Zatvori">×</a>
          <img src="<%= image.url %>" alt="<%= image.title %>">
        </div>
      <% }) %>
    </section>
  </main>
</body>
</html>